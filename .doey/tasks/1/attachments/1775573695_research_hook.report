```
Edit /Users/frikk.jarl/Documents/GitHub/doey/.claude/hooks/on-session-start.sh

Insert AFTER line 207 (after the `fi` that closes the team definition block), BEFORE line 209 (`_TITLE=""`):

# Context overlay — set env var pointing to project-specific per-role context file
_overlay_base="${wt_dir:-$PROJECT_DIR}/.doey/context"
_overlay_file=""
# Priority 1: team-specific role overlay (e.g., seo-technical.md)
[ -n "${_team_role:-}" ] && [ -f "${_overlay_base}/${_team_role}.md" ] && _overlay_file="${_overlay_base}/${_team_role}.md"
# Priority 2: base role overlay (e.g., worker.md, coordinator.md)
[ -z "$_overlay_file" ] && [ -f "${_overlay_base}/${ROLE}.md" ] && _overlay_file="${_overlay_base}/${ROLE}.md"
# Priority 3: catch-all overlay
[ -z "$_overlay_file" ] && [ -f "${_overlay_base}/all.md" ] && _overlay_file="${_overlay_base}/all.md"
if [ -n "$_overlay_file" ] && [ -w "${CLAUDE_ENV_FILE:-/dev/null}" ]; then
  echo "export DOEY_CONTEXT_OVERLAY=\"${_overlay_file}\"" >> "$CLAUDE_ENV_FILE"
fi
```


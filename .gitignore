.DS_Store
.beads/
.claude/scheduled_tasks.lock
.doey/*
!.doey/tasks/
!.doey/plans/
!.doey/plans/*.md
!.doey/context/
!.doey/context/*.md
!.doey/config.sh
!.doey/cleanup-tasks.sh
!.doey/*.team.md

# Inside tasks: ignore all, then whitelist specific patterns
.doey/tasks/*
!.doey/tasks/*.task
!.doey/tasks/*.result.json
!.doey/tasks/*.report
!.doey/tasks/*.status
!.doey/tasks/*.status.log
!.doey/tasks/*/

# Inside task subdirs: ignore all, then whitelist artifact dirs
.doey/tasks/*/*
!.doey/tasks/*/attachments/
!.doey/tasks/*/results/
!.doey/tasks/*/reports/

# Inside artifact dirs: ignore all, then whitelist by extension
.doey/tasks/*/attachments/*
!.doey/tasks/*/attachments/*.md
!.doey/tasks/*/attachments/*.report
.doey/tasks/*/results/*
!.doey/tasks/*/results/*.json
.doey/tasks/*/reports/*
!.doey/tasks/*/reports/*.report

# Exclude temp files
.doey/tasks/*.task.tmp.*
tui/doey-ctl
tui/cmd/doey-ctl/doey-ctl
tui/doey-loading
tui/doey-router
tui/doey-masterplan-tui
tui/doey-term
tui/gen-constants

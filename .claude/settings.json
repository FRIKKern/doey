{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/on-prompt-submit.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/on-pre-tool-use.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-tool-lint.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/stop-status.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/stop-results.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/stop-notify-manager.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/stop-notify-session-manager.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/stop-notify.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
